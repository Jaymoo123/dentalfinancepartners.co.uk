# Estate console environment variables.
#
# All keys are server-only (no NEXT_PUBLIC_ prefix needed — this app has
# no public pages and no client-side analytics SDK).
#
# Copy this file to .env.local and fill in the values.

# Supabase project URL (from Supabase dashboard -> Settings -> API)
SUPABASE_URL=https://your-project.supabase.co

# Service role key (server-only, never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Single shared admin key for the estate console login.
# Change this to a strong random string. Rotating it invalidates all sessions.
ADMIN_DASHBOARD_KEY=change-me-to-a-strong-random-key
