{
  "site": "construction-cis",
  "displayName": "Trade Tax Specialists",
  "paths": {
    "repoRoot": "C:/Users/user/Documents/Accounting",
    "worktreeBase": "C:/Users/user/Documents",
    "worktreePattern": "Accounting-wt-{site}-{wavekind}{wave}-{bucket}",
    "branchPattern": "{site}-{wavekind}{wave}-{bucket}",
    "docsDir": "docs/construction-cis",
    "briefsDir": "briefs/construction-cis",
    "sessionsDir": "docs/sessions/construction-cis",
    "blogContentDir": "construction-cis/web/content/blog",
    "blogRoutesDir": "construction-cis/web/src/app/blog",
    "buildDir": "construction-cis/web",
    "housePositions": "docs/construction-cis/house_positions.md",
    "netnewProgram": "docs/_engines/NETNEW_PROGRAM.md",
    "siteConfigJson": "construction-cis/niche.config.json"
  },
  "vercel": {
    "projectJson": "construction-cis/web/.vercel/project.json",
    "productionDomain": "www.tradetaxspecialists.co.uk"
  },
  "indexnow": {
    "module": "optimisation_engine.indexing.submit_indexnow"
  },
  "pillars": [
    "what-is-cis",
    "cis-gross-payment-status-guide",
    "cis-sole-trader-vs-limited-company",
    "cis-april-2026-rule-changes",
    "cis-self-assessment-complete-guide",
    "cis-vs-paye-complete-comparison",
    "gross-payment-status-cash-flow-guide",
    "cis-back-years-refund-guide"
  ],
  "wave": {
    "buckets": [
      "a",
      "b",
      "c"
    ],
    "bucketsUpper": [
      "A",
      "B",
      "C"
    ],
    "megaWaveSize": 60,
    "batchSize": 6,
    "waveKind": "wave"
  },
  "naming": {
    "launchPromptsFile": "WAVE{wave}_LAUNCH_PROMPTS.md",
    "startHereFile": "WAVE{wave}_SESSION_{bucketUpper}_START_HERE.md",
    "trackerFile": "wave{wave}_page_tracker.md",
    "flagsFile": "wave{wave}_site_wide_flags.md",
    "qaFile": "wave{wave}_questions_session_{bucketUpper}.md",
    "discoveryFile": "wave{wave}_discovery_log_session_{bucketUpper}.md",
    "promptExtractDir": "wave{wave}_prompts",
    "briefSubdir": "wave{wave}",
    "cannibCheckFile": "wave{wave}_cannibalisation_check.md"
  }
}
