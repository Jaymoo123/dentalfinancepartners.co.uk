# Public site URL (no trailing slash) — used for metadata, canonical URLs, and sitemap
# For local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# For production (set in Vercel/deployment environment):
# NEXT_PUBLIC_SITE_URL=https://www.hollowaydavies.co.uk

# Supabase (for lead form submissions + newsletter subscribers)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Server-only key for newsletter writes AND analytics ingest (/api/track route).
# Used only by API routes — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Server secret for the once-per-site live-form probe; rewrites the row to source=test.
LEAD_PROBE_SECRET=replace-with-random-secret

# Resend (transactional + nurture email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sending identity used by transactional and nurture emails.
RESEND_FROM_EMAIL=hello@hollowaydavies.co.uk
RESEND_FROM_NAME=Holloway Davies
RESEND_REPLY_TO=hello@hollowaydavies.co.uk
# Resend audience id for newsletter subscriber sync (optional; omit to disable audience sync).
RESEND_AUDIENCE_ID=

# ── Nurture engine identity (EN-06: engine refuses to operate if these are absent) ──
# From address for nurture emails. No hardcoded fallback — must be set.
NURTURE_FROM_EMAIL=hello@hollowaydavies.co.uk
NURTURE_FROM_NAME=Holloway Davies
NURTURE_REPLY_TO=hello@hollowaydavies.co.uk

# Signing secret for /api/nurture/events webhook (Resend Svix signature).
# Configure endpoint in Resend dashboard: https://www.hollowaydavies.co.uk/api/nurture/events
# Copy the signing secret (starts with whsec_) into this env var.
# SEC-05: route returns 503 (not processing) when this is unset.
NURTURE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 32+ char secret for stateless HMAC double-opt-in tokens (confirm + unsubscribe links).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# When set: new subscribers receive a confirmation email before being activated.
# When unset: subscribers are activated immediately (single opt-in).
NURTURE_TOKEN_SECRET=replace-with-32-byte-hex-secret

# ── EN-04 dormancy gate ───────────────────────────────────────────────────────
# The nurture engine is DORMANT BY DEFAULT. No marketing email leaves until
# CRON_SECRET is set. With CRON_SECRET unset:
#   - Subscriber opt-ins are recorded in the subscribers table.
#   - /api/nurture/send returns 401 (unauthorized) on every cron tick.
#   - Zero emails leave, zero provider calls are made.
#
# TO ARM the engine (operator decision required, never auto-armed):
#   1. Set NURTURE_FROM_EMAIL, NURTURE_FROM_NAME, NURTURE_REPLY_TO above.
#   2. Set NURTURE_TOKEN_SECRET above (enables double opt-in).
#   3. Set NURTURE_WEBHOOK_SECRET above (Resend dashboard endpoint).
#   4. Set CRON_SECRET below AND configure it in Vercel project settings.
#   5. Confirm in Resend dashboard that the sending domain is verified.
# Once CRON_SECRET is set the next cron run will begin sending queued opt-ins.
#
# Vercel Cron injects Authorization: Bearer <CRON_SECRET> on scheduled invocations.
# CRON_SECRET=replace-with-random-hex-shared-with-vercel-cron
# (Leave commented out to keep the engine dormant — this is the default posture.)

# Vercel Cron auth (Vercel injects this on cron invocations)
CRON_SECRET=replace-with-random-hex-shared-with-vercel-cron

# Operator console (GAP-3, PF-05)
# 32+ char random secret used to authenticate the /admin/analytics console.
# The cookie session token is derived as SHA-256("console-session:<key>").
# Changing this value invalidates all active sessions.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_DASHBOARD_KEY=replace-with-random-secret

# ── Multi-step mini lead form ─────────────────────────────────────────────────
# Set to 1 to enable the two-step MiniCapture flow (role+message / contact).
# Off by default (single-step rollback path). Toggle in Vercel env to activate.
# NEXT_PUBLIC_MINIFORMS_MULTISTEP=1

# ── Lead-nurture pipeline (Phase 1, DRY-RUN by default) ──────────────────────
# Master arm: unset = dormant (no real messages sent; state machine advances in
# test mode only). Set to 1 to arm the pipeline (operator decision required).
# LEAD_NURTURE_ENABLED=1

# Per-channel flags (only take effect when LEAD_NURTURE_ENABLED=1):
# LEAD_NURTURE_EMAIL_ENABLED=1
# LEAD_NURTURE_SMS_ENABLED=1
# LEAD_NURTURE_WHATSAPP_ENABLED=1

# Auto-pause on guardrail breach (only when LEAD_NURTURE_ENABLED=1):
# LEAD_NURTURE_AUTOPAUSE_ENABLED=1

# Resend lead-notification routing:
LEADS_NOTIFY_TO=junaydmoughal@hotmail.co.uk
# LEADS_NOTIFY_CC=           # optional CC recipient(s), comma-separated
# LEADS_NOTIFY_CC_EXCLUDE_SOURCES=property,test  # default

# Lead-service email identity (from / reply-to for nurture follow-up emails):
LEAD_SERVICE_FROM_NAME=Holloway Davies
LEAD_SERVICE_FROM_EMAIL=team@propertytaxpartners.co.uk
LEAD_SERVICE_REPLY_TO=inbound@inbound.propertytaxpartners.co.uk

# Resend notify from/reply-to (used by guardrail alerts and digest):
RESEND_FROM_NAME=Holloway Davies
RESEND_FROM_EMAIL=leads@propertytaxpartners.co.uk

# Twilio (SMS + WhatsApp): leave unset to keep SMS/WhatsApp channels dormant.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_SMS_FROM=+447700000000
# TWILIO_WHATSAPP_FROM=+447700000000
# TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # optional API Key auth
# TWILIO_API_KEY_SECRET=                                 # optional API Key auth
# TWILIO_WA_CONTENT_LEAD_WELCOME=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WA_CONTENT_LEAD_REMINDER=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Lead-nurture token secret (HMAC signing for opt-out / confirm links):
# LEAD_NURTURE_TOKEN_SECRET=replace-with-32-byte-hex-secret
