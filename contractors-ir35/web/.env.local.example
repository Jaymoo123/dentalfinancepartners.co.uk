# Public site URL (no trailing slash) — used for metadata, canonical URLs, and sitemap
# For local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# For production (set in Vercel/deployment environment):
# NEXT_PUBLIC_SITE_URL=https://www.contractortaxaccountants.co.uk

# Supabase (for lead form submissions)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service-role key (server-side only — analytics ingest via /api/track)
# NEVER expose to the client. Set in Vercel environment (server-only).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin console key — protects /admin/analytics (OB-01)
# Generate a strong random string (e.g. openssl rand -base64 32)
ADMIN_DASHBOARD_KEY=your-admin-key-here

# Lead probe secret — allows the once-per-site live-form synthetic probe to
# submit through the real form and have the server rewrite source='test' so
# the lead never reaches the partner CC and is never enriched.
# Set this to the same value in the Vercel project environment (all envs).
LEAD_PROBE_SECRET=your-probe-secret-here

# Mini lead-capture multi-step flow (about-you / contact-details two-step).
# OFF until deploy: leave unset for the single-step form (rollback-safe default).
# Set to "1" in the Vercel environment only when flipping the multi-step flow live.
# NEXT_PUBLIC_MINIFORMS_MULTISTEP=1

# ── Lead nurture (DORMANT by default) ────────────────────────────────────────
# DRY-RUN mode: leave LEAD_NURTURE_ENABLED unset (or commented out). The state
# machine advances normally on every new lead, but no messages leave. Enrol
# counts will appear in Supabase lead_nurture_state even while dormant.
# To arm: set LEAD_NURTURE_ENABLED=1 AND the per-channel flags below.
#
# DORMANT (default -- do not uncomment until owner signs off):
# LEAD_NURTURE_ENABLED=1
# LEAD_NURTURE_EMAIL_ENABLED=1
# LEAD_NURTURE_SMS_ENABLED=1
# LEAD_NURTURE_WHATSAPP_ENABLED=1

# Resend: shared Property domain. RESEND_API_KEY is the same key used across
# the estate. From/reply-to default to the Property Resend domain; override
# only if an ir35-specific sending domain is provisioned later.
# RESEND_API_KEY=re_...
# LEAD_SERVICE_FROM_NAME=Contractor Tax Accountants
# LEAD_SERVICE_FROM_EMAIL=leads@propertytaxpartners.co.uk
# LEAD_SERVICE_REPLY_TO=inbound@inbound.propertytaxpartners.co.uk

# Twilio (SMS + WhatsApp): shared credentials across the estate.
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_SMS_FROM=+44...
# TWILIO_WHATSAPP_FROM=+44...

# Nurture token secret (signs booking/confirm/optout tokens). Must match the
# value set on other sites in the estate (tokens are cross-site-verifiable).
# LEAD_NURTURE_TOKEN_SECRET=...

# Cron auth secret. Must match the CRON_SECRET set in Vercel project settings.
# CRON_SECRET=...

# Auto-pause: set to "1" to let the guardrail auto-pause the nurture system on
# breach. Off by default (alerts only).
# LEAD_NURTURE_AUTOPAUSE_ENABLED=1
