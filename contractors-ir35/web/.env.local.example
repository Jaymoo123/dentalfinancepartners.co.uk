# Public site URL (no trailing slash) — used for metadata, canonical URLs, and sitemap
# For local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# For production (set in Vercel/deployment environment):
# NEXT_PUBLIC_SITE_URL=https://www.contractortaxaccountants.co.uk

# Supabase (for lead form submissions)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service-role key (server-side only — analytics ingest via /api/track)
# NEVER expose to the client. Set in Vercel environment (server-only).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin console key — protects /admin/analytics (OB-01)
# Generate a strong random string (e.g. openssl rand -base64 32)
ADMIN_DASHBOARD_KEY=your-admin-key-here

# Lead probe secret — allows the once-per-site live-form synthetic probe to
# submit through the real form and have the server rewrite source='test' so
# the lead never reaches the partner CC and is never enriched.
# Set this to the same value in the Vercel project environment (all envs).
LEAD_PROBE_SECRET=your-probe-secret-here

# Mini lead-capture multi-step flow (about-you / contact-details two-step).
# OFF until deploy: leave unset for the single-step form (rollback-safe default).
# Set to "1" in the Vercel environment only when flipping the multi-step flow live.
# NEXT_PUBLIC_MINIFORMS_MULTISTEP=1
