# Public site URL (no trailing slash) — used for metadata, canonical URLs, and sitemap
# For local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# For production (set in Vercel/deployment environment):
# NEXT_PUBLIC_SITE_URL=https://www.medicalaccounts.co.uk

# Supabase (for lead form submissions + analytics ingest)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Server-only key for analytics ingest (/api/track route) and the lead chokepoint (/api/leads/submit).
# Used only by API routes — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Analytics 4 measurement ID (GA4 tag in layout.tsx — do NOT remove)
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# Note: The GA4 ID is embedded in the niche config file, not this env var.
# The config reads it from niche.seo.google_analytics_id.

# Analytics first-party tracking
# The /api/track route uses SUPABASE_SERVICE_ROLE_KEY (above) to write
# web_sessions and web_events. No additional env var needed beyond service role.
# storagePrefix: "ma" — FROZEN at adoption per Phase D spec (never change).
# Site key: "medical" — derived from niche config (PF-07, never a literal in code).

# Lead probe secret — set per site at deploy time.
# Used by the once-per-site live-form probe to rewrite source to "test" (no
# partner CC, no enrichment). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LEAD_PROBE_SECRET=replace-with-random-secret

# Operator console (Phase D, PF-05)
# 32+ char random secret used to authenticate the /admin/analytics console.
# The cookie session token is derived as SHA-256("console-session:<key>").
# Changing this value invalidates all active sessions.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_DASHBOARD_KEY=replace-with-random-secret

# Set to "1" to allow lead submissions outside production (dev/preview testing).
# Default: only production writes real leads.
# LEADS_ALLOW_NONPROD_SUBMIT=1

# Multi-step mini lead form — set to "1" to enable two-step capture (role+message / contact).
# OFF until deploy: omit or set to "0" for the single-step layout (rollback path).
# NEXT_PUBLIC_MINIFORMS_MULTISTEP=1

# ── Lead-nurture stack (DORMANT: do NOT set until the owner arms it) ──────────
#
# LEAD_NURTURE_ENABLED=1 is the master arm. Until this is set, the state machine
# advances in dry-run but no email or SMS is ever sent. All variables below are
# optional until the system is armed.
#
# Master arm (UNSET = dormant):
# LEAD_NURTURE_ENABLED=1
#
# Per-channel arms (all default off; set to "1" when armed):
# LEAD_NURTURE_EMAIL_ENABLED=1
# LEAD_NURTURE_SMS_ENABLED=1
# LEAD_NURTURE_WHATSAPP_ENABLED=1
#
# Auto-pause on guardrail breach (optional; default off):
# LEAD_NURTURE_AUTOPAUSE_ENABLED=1
#
# Email sender (shared Property Resend domain, owner decision):
# LEAD_SERVICE_FROM_NAME=Medical Accountants UK
# LEAD_SERVICE_FROM_EMAIL=leads@propertytaxpartners.co.uk
# LEAD_SERVICE_REPLY_TO=inbound@inbound.propertytaxpartners.co.uk
#
# Resend API key (shared with other sites, lives in shared env):
# RESEND_API_KEY=re_...
#
# SMS / WhatsApp via Twilio (optional; only needed when SMS arm is set):
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_API_KEY_SECRET=your-key-secret
# TWILIO_SMS_FROM=+44xxxxxxxxxx
# TWILIO_WHATSAPP_FROM=+44xxxxxxxxxx
# TWILIO_WA_CONTENT_LEAD_WELCOME=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WA_CONTENT_LEAD_REMINDER=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Signed token secret for confirm/optout/profile URLs (shared estate key):
# LEAD_NURTURE_TOKEN_SECRET=replace-with-32-char-random-secret
#
# Cron auth (same secret used by Vercel Cron to call /api/cron/*):
# CRON_SECRET=replace-with-random-secret
