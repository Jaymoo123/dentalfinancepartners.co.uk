# Public site URL (no trailing slash) — used for metadata, canonical URLs, and sitemap
# For local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# For production (set in Vercel/deployment environment):
# NEXT_PUBLIC_SITE_URL=https://www.medicalfinancepartners.co.uk

# Supabase (for lead form submissions + analytics ingest)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Server-only key for analytics ingest (/api/track route).
# Used only by API routes — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend (transactional email — lead notifications)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Analytics 4 measurement ID (GA4 tag in layout.tsx — do NOT remove)
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# Note: The GA4 ID is embedded in the niche config file, not this env var.
# The config reads it from niche.seo.google_analytics_id.

# Analytics first-party tracking
# The /api/track route uses SUPABASE_SERVICE_ROLE_KEY (above) to write
# web_sessions and web_events. No additional env var needed beyond service role.
# storagePrefix: "ma" — FROZEN at adoption per Phase D spec (never change).
# Site key: "medical" — derived from niche config (PF-07, never a literal in code).

# Operator console (Phase D, PF-05)
# 32+ char random secret used to authenticate the /admin/analytics console.
# The cookie session token is derived as SHA-256("console-session:<key>").
# Changing this value invalidates all active sessions.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_DASHBOARD_KEY=replace-with-random-secret

# CH (Companies House) API key — used by research/landlord-tax-index if ported.
# Not currently needed for Medical. Leave blank.
# CH_API_KEY=your-ch-api-key-here
