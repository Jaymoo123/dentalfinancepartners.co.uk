# Agency Founder Finance - environment variables
#
# Copy this to .env (NEVER commit .env) for local pipeline scripts.
# For Vercel deployment, set the NEXT_PUBLIC_* and SUPABASE_* vars in the
# Vercel project Environment Variables UI.

# ----------------------------------------------------------------------------
# Required for the website (set these in Vercel dashboard for production)
# ----------------------------------------------------------------------------

# Supabase — public (anon) key used client-side for lead form submissions
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase — service role key used server-side by Python pipeline. NEVER expose
# this to the browser. Vercel doesn't need it (pipeline runs locally), but
# set it locally if you run the pipeline scripts.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=eyJ...service_role...

# Site URL - used for canonical URLs and absolute links
NEXT_PUBLIC_SITE_URL=https://www.agencyfounderfinance.co.uk

# ----------------------------------------------------------------------------
# Required only for the Python content pipeline (local only, NOT in Vercel)
# ----------------------------------------------------------------------------

# DeepSeek — content generation
DEEPSEEK_API_KEY=sk-...

# Pexels — automatic hero images on blog posts
PEXELS_API_KEY=...

# Serper — Google SERP scraping for keyword/competitor research
SERPER_API_KEY=...

# ----------------------------------------------------------------------------
# Optional / future
# ----------------------------------------------------------------------------

# Google Analytics 4 (when you have it - set in Vercel as NEXT_PUBLIC)
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Resend - guide download email delivery (when set up)
# RESEND_API_KEY=re_...
