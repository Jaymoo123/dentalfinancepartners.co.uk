# Public site URL (no trailing slash) — used for metadata, canonical URLs, and sitemap
# For local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# For production (set in Vercel/deployment environment):
# NEXT_PUBLIC_SITE_URL=https://www.agencyfounderfinance.co.uk

# Supabase (for lead form submissions + analytics ingest)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Server-only key for analytics ingest (/api/track route).
# Used only by API routes — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend (transactional email) — shared by the health-check delivery emails
# (lib/resend.ts) AND the nurture engine provider (lib/nurture-provider.ts).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Health-check delivery identity (lib/resend.ts only — NOT used by nurture):
# RESEND_FROM_NAME=Agency Founder Finance
# RESEND_FROM_EMAIL=hello@agencyfounderfinance.co.uk
# RESEND_REPLY_TO=hello@agencyfounderfinance.co.uk

# ── Nurture engine (GAP-5 shared composition, /api/nurture/*) ─────────────────
# Replaces the deleted legacy fork (/api/newsletter/*, /api/cron/newsletter-drip,
# /api/resend/webhook). ENV MIGRATION from the old fork's names:
#   RESEND_FROM_EMAIL      → NURTURE_FROM_EMAIL    (nurture identity; RESEND_* names
#   RESEND_FROM_NAME       → NURTURE_FROM_NAME      remain in use by health-check
#   RESEND_REPLY_TO        → NURTURE_REPLY_TO       emails — keep both sets)
#   RESEND_WEBHOOK_SECRET  → NURTURE_WEBHOOK_SECRET (re-point the Resend dashboard
#                            endpoint to /api/nurture/events and copy its whsec_)
#   NEWSLETTER_TOKEN_SECRET→ NURTURE_TOKEN_SECRET   (rotating invalidates in-flight
#                            confirm/unsubscribe links minted by the old fork)
#   RESEND_AUDIENCE_ID     → (retired — the shared engine does not manage Resend
#                            Audiences/Contacts; remove from env)
#   CRON_SECRET            → CRON_SECRET            (same name; see arming below)
# EN-06: no fallbacks. The engine refuses to operate if identity vars are unset.
NURTURE_FROM_EMAIL=hello@agencyfounderfinance.co.uk
NURTURE_FROM_NAME=Agency Founder Finance
NURTURE_REPLY_TO=hello@agencyfounderfinance.co.uk

# Signing secret for /api/nurture/events webhook (Resend Svix signature).
# Configure endpoint in Resend dashboard:
#   https://www.agencyfounderfinance.co.uk/api/nurture/events
NURTURE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 32+ char secret for stateless HMAC double-opt-in tokens (confirm + unsubscribe).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# When set: new subscribers receive a confirmation email before being activated.
NURTURE_TOKEN_SECRET=replace-with-32-byte-hex-secret

# ── EN-04 arming gate (operator decision at deploy — NOT decided in code) ─────
# CRON_SECRET unset  → DORMANT: opt-ins recorded, /api/nurture/send returns 401,
#                      zero emails leave.
# CRON_SECRET set    → ARMED: the daily cron (vercel.json → /api/nurture/send)
#                      sends due drip steps with claim-before-send idempotency.
# The legacy fork was ARMED in the live Vercel project. Whether CRON_SECRET
# carries over (stays armed) or is withheld (goes dormant) is the operator's
# call at deploy time.
# CRON_SECRET=replace-with-random-hex-shared-with-vercel-cron

# ── Lead-form probe (once-per-site live-form validation) ──────────────────────
# A submit carrying probe_secret matching this value is rewritten to source='test'
# (no partner CC, no enrichment) so the live-form probe exercises the real form
# -> route -> insert -> notify path without emailing the partner firm.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set in Vercel project env AND root .env so estate_synthetic_lead_check.mjs
# --route mode can exercise the real chokepoint.
# LEAD_PROBE_SECRET=replace-with-32-byte-hex-secret

# Google Analytics 4 measurement ID
# The GA4 ID lives in niche.seo.google_analytics_id (niche.config.json), not here.
# Agency currently has no GA4 ID configured; field is empty in niche.config.json.
# GA4 gating: ConsentedScripts (shared web-shared component, already in layout.tsx)
# handles all GA4 delivery under the consent gate. The site-local GoogleAnalytics
# component was removed from <head> in Wave 5 R1 (it bypassed the consent gate).
# Do NOT re-add an unconditional GoogleAnalytics component to <head>.
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ── uk-tax-rates.json (read-only reference, not an env var) ───────────────────
# src/app/api/uk-tax-rates.json is a static JSON route serving current UK tax
# rates for agency founders (BADR, CT, dividend, NIC, CGT, AMAP). It is served
# at /api/uk-tax-rates.json with runtime="edge" and Cache-Control max-age=86400.
# It has no associated env var; the data is baked into the file at build time.
# The compute libs (salary-dividend.ts, badr-cgt.ts, etc.) use TypeScript
# constants, not this JSON, so there is no drift risk between JSON and compute.
# Reviewers: verify the rates in uk-tax-rates.json match house_positions.md §2-§5.

# Analytics first-party tracking
# The /api/track route uses SUPABASE_SERVICE_ROLE_KEY (above) to write
# web_sessions and web_events. No additional env var needed beyond service role.
# storagePrefix: "aff" — FROZEN at adoption per Phase D spec (never change).
# Site key: "agency" — derived from niche config (PF-07, never a literal in code).

# Operator console (Phase D, PF-05)
# 32+ char random secret used to authenticate the /admin/analytics console.
# The cookie session token is derived as SHA-256("console-session:<key>").
# Changing this value invalidates all active sessions.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_DASHBOARD_KEY=replace-with-random-secret
