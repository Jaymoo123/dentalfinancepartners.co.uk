# Public site URL (no trailing slash) — used for metadata, canonical URLs, and sitemap
# For local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# For production (set in Vercel/deployment environment):
# NEXT_PUBLIC_SITE_URL=https://www.tradetaxspecialists.co.uk

# Multi-step mini lead form — set to "1" to enable two-step capture (role+message / contact).
# Leave OFF (omit or "0") until deploy; single-step is the rollback path.
# NEXT_PUBLIC_MINIFORMS_MULTISTEP=1

# Supabase (for lead form submissions)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service-role key (server-side only — analytics ingest via /api/track)
# NEVER expose to the client. Set in Vercel environment (server-only).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin console key — protects /admin/analytics (OB-01)
# Generate a strong random string (e.g. openssl rand -base64 32)
ADMIN_DASHBOARD_KEY=your-admin-key-here

# Live-form probe secret (once-per-site post-deploy battery).
# When a lead form submission includes a matching probe_secret, the server
# rewrites source='test' (no partner CC, no enrichment). Set this per site
# in Vercel environment variables too.
# Generate: openssl rand -base64 32
LEAD_PROBE_SECRET=your-probe-secret-here

# ── Lead nurture (DORMANT by default) ────────────────────────────────────────
#
# All vars below are UNSET in dry-run. The state machine advances and DB rows
# are written, but no emails or SMS leave while LEAD_NURTURE_ENABLED is unset.
#
# To arm (owner decision required):
#   LEAD_NURTURE_ENABLED=1
#   LEAD_NURTURE_EMAIL_ENABLED=1
#   LEAD_NURTURE_SMS_ENABLED=1          # optional, requires Twilio
#   LEAD_NURTURE_WHATSAPP_ENABLED=1     # optional, requires Twilio WA
#   LEAD_NURTURE_AUTOPAUSE_ENABLED=1    # auto-pause on guardrail breach
#
# Resend (shared Property domain -- no CIS-specific sending domain required):
# RESEND_API_KEY=re_...
# RESEND_FROM_NAME=Trade Tax Specialists
# RESEND_FROM_EMAIL=leads@propertytaxpartners.co.uk
# LEAD_SERVICE_FROM_NAME=Trade Tax Specialists
# LEAD_SERVICE_FROM_EMAIL=leads@propertytaxpartners.co.uk
# LEAD_SERVICE_REPLY_TO=inbound@inbound.propertytaxpartners.co.uk
#
# Cron auth (must match vercel.json CRON_SECRET):
# CRON_SECRET=your-cron-secret-here
#
# Token signing (for opt-out and confirm links):
# LEAD_NURTURE_TOKEN_SECRET=your-token-secret-here
#
# Twilio (optional -- SMS/WhatsApp only):
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_SMS_FROM=+44...
# TWILIO_WHATSAPP_FROM=+44...
# TWILIO_WA_CONTENT_LEAD_WELCOME=HX...
# TWILIO_WA_CONTENT_LEAD_REMINDER=HX...
