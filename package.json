{
  "name": "accounting-network",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-site UK accounting lead-gen network. Root of the npm workspace; per-site Next.js apps live in {site}/web and shared code in packages/*.",
  "scripts": {
    "gate:property": "python scripts/predeploy_gate.py"
  },
  "workspaces": [
    "packages/*",
    "Dentists/web",
    "Property/web",
    "Medical/web",
    "Solicitors/web",
    "generalist/web",
    "digital-agency/web",
    "contractors-ir35/web",
    "construction-cis/web",
    "console/web",
    "charities/web",
    "hospitality/web"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "puppeteer-core": "^25.1.0",
    "vitest": "^2.1.0"
  }
}
